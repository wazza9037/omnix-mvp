# OMNIX Configuration
# Copy to .env and customize for your deployment.

# ── Environment ──
OMNIX_ENV=development          # development | staging | production

# ── HTTP Server ──
OMNIX_HOST=0.0.0.0
OMNIX_PORT=8765

# ── WebSocket Server ──
OMNIX_WS_ENABLED=true
OMNIX_WS_PORT=8766

# ── Logging ──
OMNIX_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
OMNIX_LOG_JSON=false           # true for structured JSON logs (log pipelines)

# ── Authentication ──
OMNIX_JWT_SECRET=               # Auto-generated if empty. Set for production!
OMNIX_JWT_EXPIRY=86400          # Token lifetime in seconds (default: 24 hours)
OMNIX_JWT_REFRESH_EXPIRY=604800 # Refresh token lifetime (default: 7 days)
OMNIX_GUEST_MODE=true           # Allow anonymous read-only access
OMNIX_ADMIN_USER=admin          # Default admin username (created on first run)
OMNIX_ADMIN_PASSWORD=omnix-admin # Default admin password — CHANGE IN PRODUCTION!
OMNIX_ADMIN_EMAIL=admin@omnix.local

# ── Database ──
OMNIX_DB_BACKEND=memory         # memory | sqlite | postgres
OMNIX_DB_PATH=omnix.db          # SQLite file path (when backend=sqlite)
OMNIX_DB_URL=                   # Postgres URL: postgresql://user:pass@host:5432/omnix

# ── Security ──
OMNIX_CORS_ORIGINS=*            # Comma-separated allowed origins, or * for all
OMNIX_RATE_LIMIT_AUTH=10        # Auth endpoint rate limit (requests/minute)
OMNIX_RATE_LIMIT_API=100        # General API rate limit (requests/minute)
OMNIX_MAX_REQUEST_SIZE=20971520 # Max request body in bytes (default: 20MB)

# ── Telemetry ──
OMNIX_TELEMETRY_CACHE_MS=200
OMNIX_TELEMETRY_WINDOW=120

# ── Connectors ──
OMNIX_CONNECTOR_TICK_S=0.5
OMNIX_RECONNECT_MAX_S=30.0
OMNIX_RECONNECT_INITIAL_S=1.0
OMNIX_HEARTBEAT_TIMEOUT_S=10.0

# ── Simulation ──
OMNIX_SIM_TICK_S=0.05
OMNIX_SIM_MAX_DURATION_S=120.0

# ── External Services ──
OMNIX_WIKI_TIMEOUT_S=4.0

# ── Feature Flags ──
OMNIX_USE_NUMPY=true
